<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meta Ads Complete Performance Diary</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080810;
    --s1: #0f0f1a;
    --s2: #161622;
    --border: #1e1e2e;
    --accent: #5b6ef5;
    --text: #dcdcee;
    --muted: #52526e;
    --ex: #818cf8; --ex-bg: rgba(91,110,245,0.12); --ex-b: rgba(91,110,245,0.25);
    --g:  #34d399; --g-bg:  rgba(16,185,129,0.12); --g-b:  rgba(16,185,129,0.25);
    --vg: #6ee7b7; --vg-bg: rgba(16,185,129,0.2);  --vg-b: rgba(16,185,129,0.35);
    --av: #fbbf24; --av-bg: rgba(245,158,11,0.12); --av-b: rgba(245,158,11,0.25);
    --po: #f87171; --po-bg: rgba(239,68,68,0.12);  --po-b: rgba(239,68,68,0.25);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'DM Sans',sans-serif;
    padding:48px 20px 100px;
    background-image:
      radial-gradient(ellipse at 15% 5%, rgba(91,110,245,0.07) 0%,transparent 55%),
      radial-gradient(ellipse at 85% 90%, rgba(124,58,237,0.05) 0%,transparent 55%);
  }
  .wrap{max-width:820px;margin:0 auto;}

  /* ── Header ── */
  .hdr{text-align:center;margin-bottom:64px;}
  .hdr-badge{
    display:inline-block;
    background:linear-gradient(135deg,rgba(91,110,245,0.18),rgba(124,58,237,0.18));
    border:1px solid rgba(91,110,245,0.3);
    color:#a5b4fc;font-size:10px;font-weight:600;
    letter-spacing:3px;text-transform:uppercase;
    padding:6px 18px;border-radius:100px;margin-bottom:22px;
  }
  .hdr h1{
    font-family:'Syne',sans-serif;
    font-size:clamp(28px,5vw,50px);font-weight:800;
    background:linear-gradient(135deg,#fff 30%,#8b9cf7 80%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    background-clip:text;line-height:1.1;margin-bottom:12px;
  }
  .hdr p{color:var(--muted);font-size:14px;line-height:1.6;}

  /* ── TOC ── */
  .toc{
    background:var(--s1);border:1px solid var(--border);
    border-radius:16px;padding:28px 32px;margin-bottom:56px;
  }
  .toc h3{
    font-family:'Syne',sans-serif;font-size:13px;font-weight:700;
    letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:16px;
  }
  .toc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;}
  .toc-item{
    display:flex;align-items:center;gap:10px;
    padding:10px 14px;border-radius:10px;
    background:var(--s2);border:1px solid var(--border);
    font-size:13px;color:#9999bb;text-decoration:none;
    transition:border-color 0.2s,color 0.2s;
  }
  .toc-item:hover{border-color:rgba(91,110,245,0.4);color:#c5c9f7;}
  .toc-num{font-family:'Syne',sans-serif;font-size:11px;color:var(--accent);font-weight:700;min-width:18px;}

  /* ── Section Label ── */
  .sec{
    font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;
    color:var(--accent);margin:56px 0 18px;
    display:flex;align-items:center;gap:12px;
  }
  .sec::after{content:'';flex:1;height:1px;background:var(--border);}

  /* ── Card ── */
  .card{
    background:var(--s1);border:1px solid var(--border);
    border-radius:16px;padding:26px 28px;margin-bottom:14px;
    position:relative;overflow:hidden;
    transition:border-color 0.2s,transform 0.2s;
  }
  .card:hover{border-color:rgba(91,110,245,0.25);transform:translateY(-1px);}
  .card::before{
    content:'';position:absolute;top:0;left:0;
    width:3px;height:100%;
    background:linear-gradient(180deg,var(--accent),#7c3aed);
  }
  .card-title{
    font-family:'Syne',sans-serif;font-size:17px;font-weight:700;
    color:#fff;margin-bottom:4px;
  }
  .card-sub{font-size:12px;color:var(--muted);margin-bottom:6px;}
  .card-desc{font-size:13px;color:#8888aa;line-height:1.65;margin-bottom:18px;}

  /* ── Table ── */
  table{width:100%;border-collapse:collapse;font-size:13px;}
  th{
    text-align:left;padding:8px 14px;
    background:#12121e;color:var(--muted);
    font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;
  }
  th:first-child{border-radius:8px 0 0 8px;}
  th:last-child{border-radius:0 8px 8px 0;}
  td{padding:10px 14px;border-bottom:1px solid rgba(255,255,255,0.04);color:#b8b8d0;vertical-align:middle;}
  tr:last-child td{border-bottom:none;}

  /* ── Pills ── */
  .pill{display:inline-flex;align-items:center;gap:4px;padding:3px 12px;border-radius:100px;font-size:11px;font-weight:600;white-space:nowrap;}
  .ex{background:var(--ex-bg);color:var(--ex);border:1px solid var(--ex-b);}
  .vg{background:var(--vg-bg);color:var(--vg);border:1px solid var(--vg-b);}
  .g {background:var(--g-bg); color:var(--g); border:1px solid var(--g-b);}
  .av{background:var(--av-bg);color:var(--av);border:1px solid var(--av-b);}
  .po{background:var(--po-bg);color:var(--po);border:1px solid var(--po-b);}

  /* ── Tip box ── */
  .tip{
    background:rgba(91,110,245,0.07);border:1px solid rgba(91,110,245,0.18);
    border-radius:10px;padding:14px 18px;
    font-size:13px;color:#9ba3f7;line-height:1.6;margin-top:14px;
  }
  .tip strong{color:#b0b8fb;}

  /* ── Objective matrix ── */
  .obj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-top:4px;}
  .obj-card{
    background:var(--s2);border:1px solid var(--border);
    border-radius:12px;padding:18px;
  }
  .obj-name{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:#fff;margin-bottom:10px;}
  .obj-row{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--muted);padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.04);}
  .obj-row:last-child{border-bottom:none;}
  .obj-val{color:#b8b8d0;font-weight:500;}

  /* ── Warning box ── */
  .warn{
    background:rgba(239,68,68,0.07);border:1px solid rgba(239,68,68,0.18);
    border-radius:10px;padding:14px 18px;
    font-size:13px;color:#fca5a5;line-height:1.6;margin-top:14px;
  }
  .warn strong{color:#f87171;}

  /* ── Checklist ── */
  .checklist{list-style:none;margin-top:14px;}
  .checklist li{
    padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);
    font-size:13px;color:#9999bb;display:flex;gap:10px;align-items:flex-start;
  }
  .checklist li:last-child{border-bottom:none;}
  .checklist li::before{content:'→';color:var(--accent);flex-shrink:0;margin-top:1px;}

  /* ── Footer ── */
  .footer{text-align:center;color:var(--muted);font-size:12px;margin-top:72px;padding-top:24px;border-top:1px solid var(--border);}
</style>
</head>
<body>
<div class="wrap">

<!-- Header -->
<div class="hdr">
  <div class="hdr-badge">Meta Ads · Complete Reference Diary</div>
  <h1>Meta Ads Performance Diary</h1>
  <p>Every metric across every objective — with exact good, average, poor benchmarks<br>Nepal market focused · Use this every time you analyze your ads</p>
</div>

<!-- TOC -->
<div class="toc">
  <h3>Contents</h3>
  <div class="toc-grid">
    <a class="toc-item" href="#reach"><span class="toc-num">01</span> Reach & Visibility</a>
    <a class="toc-item" href="#clicks"><span class="toc-num">02</span> Clicks & Engagement</a>
    <a class="toc-item" href="#website"><span class="toc-num">03</span> Website Performance</a>
    <a class="toc-item" href="#results"><span class="toc-num">04</span> Results & Conversions</a>
    <a class="toc-item" href="#video"><span class="toc-num">05</span> Video Metrics</a>
    <a class="toc-item" href="#messages"><span class="toc-num">06</span> Messages & Leads</a>
    <a class="toc-item" href="#quality"><span class="toc-num">07</span> Quality Rankings</a>
    <a class="toc-item" href="#budget"><span class="toc-num">08</span> Budget & Learning</a>
    <a class="toc-item" href="#audience"><span class="toc-num">09</span> Audience & Targeting</a>
    <a class="toc-item" href="#objectives"><span class="toc-num">10</span> Objective Benchmarks</a>
    <a class="toc-item" href="#roas"><span class="toc-num">11</span> ROAS & Profitability</a>
    <a class="toc-item" href="#health"><span class="toc-num">12</span> Campaign Health Check</a>
  </div>
</div>

<!-- 01 REACH & VISIBILITY -->
<div class="sec" id="reach">01 · Reach & Visibility</div>

<div class="card">
  <div class="card-title">Reach</div>
  <div class="card-sub">Unique people who saw your ad</div>
  <div class="card-desc">Number of individual people who saw your ad at least once. Always lower than Impressions.</div>
  <table>
    <tr><th>Value (Nepal)</th><th>Remark</th></tr>
    <tr><td>0 – 1,000</td><td><span class="pill po">Poor — increase budget or broaden audience</span></td></tr>
    <tr><td>1,000 – 10,000</td><td><span class="pill av">Average — decent for small budget</span></td></tr>
    <tr><td>10,000 – 50,000</td><td><span class="pill g">Good — healthy reach</span></td></tr>
    <tr><td>50,000 – 200,000</td><td><span class="pill vg">Very Good</span></td></tr>
    <tr><td>200,000+</td><td><span class="pill ex">Excellent — strong visibility</span></td></tr>
  </table>
</div>

<div class="card">
  <div class="card-title">Impressions</div>
  <div class="card-sub">Total times your ad was displayed</div>
  <div class="card-desc">Total times your ad appeared on screen — same person counted multiple times. Always ≥ Reach. Alone it means nothing — always read with CPM and CTR.</div>
  <div class="tip"><strong>Formula:</strong> Impressions ÷ Reach = Frequency. Use impressions to understand your ad's total exposure.</div>
</div>

<div class="card">
  <div class="card-title">Frequency</div>
  <div class="card-sub">Average times each person saw your ad</div>
  <div class="card-desc">High frequency = people getting bored or annoyed with your ad. This is called Ad Fatigue. Watch this closely on small audiences.</div>
  <table>
    <tr><th>Value</th><th>Remark</th></tr>
    <tr><td>1.0 – 2.0</td><td><span class="pill g">Good — perfectly healthy</span></td></tr>
    <tr><td>2.0 – 3.5</td><td><span class="pill av">Watch — starting to repeat</span></td></tr>
    <tr><td>3.5 – 5.0</td><td><span class="pill po">Poor — refresh your creative now</span></td></tr>
    <tr><td>5.0+</td><td><span class="pill po">Ad Fatigue — change ad immediately</span></td></tr>
  </table>
  <div class="tip"><strong>Fix for high frequency:</strong> Add new creative, expand your audience, or create an exclusion list of people who already engaged.</div>
</div>

<div class="card">
  <div class="card-title">CPM — Cost Per 1,000 Impressions</div>
  <div class="card-sub">How much you pay to reach 1,000 people</div>
  <div class="card-desc">Lower CPM = you're reaching more people for less money. Affected by audience size, competition, ad quality, and time of year.</div>
  <table>
    <tr><th>Value (Nepal Market)</th><th>Remark</th></tr>
    <tr><td>Below $0.50</td><td><span class="pill ex">Excellent — extremely cheap reach</span></td></tr>
    <tr><td>$0.50 – $1.50</td><td><span class="pill g">Good — very affordable</span></td></tr>
    <tr><td>$1.50 – $3.00</td><td><span class="pill av">Average — normal range</span></td></tr>
    <tr><td>$3.00 – $6.00</td><td><span class="pill po">Expensive — check targeting</span></td></tr>
    <tr><td>$6.00+</td><td><span class="pill po">Very Expensive — audience too narrow or competitive</span></td></tr>
  </table>
  <div class="tip"><strong>Why CPM rises:</strong> Audience too small, ad fatigue, low quality score, festive season (Dashain, Tihar), or targeting too specific interests.</div>
</div>

<!-- 02 CLICKS -->
<div class="sec" id="clicks">02 · Clicks & Engagement</div>

<div class="card">
  <div class="card-title">CTR — Click Through Rate</div>
  <div class="card-sub">% of people who saw your ad and clicked it</div>
  <div class="card-desc">Most important indicator of how interesting and relevant your ad is. Formula: (Link Clicks ÷ Impressions) × 100.</div>
  <table>
    <tr><th>Value</th><th>Remark</th></tr>
    <tr><td>Below 0.5%</td><td><span class="pill po">Poor — change creative or copy immediately</span></td></tr>
    <tr><td>0.5% – 1.0%</td><td><span class="pill av">Below Average — needs improvement</span></td></tr>
    <tr><td>1.0% – 2.0%</td><td><span class="pill g">Good — industry standard</span></td></tr>
    <tr><td>2.0% – 3.0%</td><td><span class="pill vg">Very Good — ad resonates well</span></td></tr>
    <tr><td>3.0% – 5.0%</td><td><span class="pill ex">Excellent — scale this ad</span></td></tr>
    <tr><td>5.0%+</td><td><span class="pill ex">Exceptional — duplicate and increase budget</span></td></tr>
  </table>
  <div class="tip"><strong>Low CTR fix:</strong> Change first image/video, rewrite first line of copy, add stronger CTA, test different offer or hook.</div>
</div>

<div class="card">
  <div class="card-title">CPC — Cost Per Link Click</div>
  <div class="card-sub">How much you pay for each click to your destination</div>
  <div class="card-desc">Directly related to CTR — higher CTR always gives lower CPC. Formula: Amount Spent ÷ Link Clicks.</div>
  <table>
    <tr><th>Value (Nepal)</th><th>Remark</th></tr>
    <tr><td>Below $0.02</td><td><span class="pill ex">Excellent — extremely cheap</span></td></tr>
    <tr><td>$0.02 – $0.10</td><td><span class="pill g">Good — very affordable</span></td></tr>
    <tr><td>$0.10 – $0.30</td><td><span class="pill av">Average — normal range</span></td></tr>
    <tr><td>$0.30 – $0.60</td><td><span class="pill po">Expensive — improve creative</span></td></tr>
    <tr><td>$0.60+</td><td><span class="pill po">Very Expensive — pause and fix ad</span></td></tr>
  </table>
</div>

<div class="card">
  <div class="card-title">Link Clicks vs Clicks (All)</div>
  <div class="card-sub">Two very different types of clicks</div>
  <div class="card-desc">These are not the same metric. Always use Link Clicks for performance decisions.</div>
  <table>
    <tr><th>Type</th><th>What It Counts</th><th>Use It For</th></tr>
    <tr><td><strong style="color:#fff">Link Clicks</strong></td><td>Only clicks to your website/destination</td><td>✅ Main metric — actual traffic</td></tr>
    <tr><td><strong style="color:#fff">Clicks (All)</strong></td><td>Website + likes + shares + profile visits + comments</td><td>⚠️ Vanity metric only</td></tr>
  </table>
</div>

<div class="card">
  <div class="card-title">Post Engagement</div>
  <div class="card-sub">Likes, comments, shares, saves on your ad</div>
  <div class="card-desc">High engagement tells Meta your ad is relevant — lowers CPM and CPC over time. Social proof (likes/comments) also builds trust with new viewers.</div>
  <table>
    <tr><th>Engagement Rate</th><th>Remark</th></tr>
    <tr><td>Below 1%</td><td><span class="pill po">Poor — ad not resonating</span></td></tr>
    <tr><td>1% – 3%</td><td><span class="pill av">Average</span></td></tr>
    <tr><td>3% – 6%</td><td><span class="pill g">Good</span></td></tr>
    <tr><td>6%+</td><td><span class="pill ex">Excellent — viral potential</span></td></tr>
  </table>
</div>

<!-- 03 WEBSITE -->
<div class="sec" id="website">03 · Website Performance</div>

<div class="card">
  <div class="card-title">Landing Page Views</div>
  <div class="card-sub">People who clicked AND waited for your page to load</div>
  <div class="card-desc">Always lower than Link Clicks. The gap between Link Clicks and Landing Page Views = people who left before the page loaded = slow website.</div>
  <table>
    <tr><th>Landing Page Views ÷ Link Clicks</th><th>Remark</th></tr>
    <tr><td>90%+</td><td><span class="pill ex">Excellent — very fast website</span></td></tr>
    <tr><td>70% – 90%</td><td><span class="pill g">Good — acceptable speed</span></td></tr>
    <tr><td>50% – 70%</td><td><span class="pill av">Average — website needs to be faster</span></td></tr>
    <tr><td>Below 50%</td><td><span class="pill po">Poor — website too slow, fix urgently</span></td></tr>
  </table>
  <div class="tip"><strong>Quick fix:</strong> Test your page at pagespeed.web.dev. Score should be 70+ on mobile. Compress images at squoosh.app.</div>
</div>

<div class="card">
  <div class="card-title">Cost Per Landing Page View</div>
  <div class="card-sub">How much you pay per actual website visitor</div>
  <div class="card-desc">More accurate than CPC for measuring real traffic cost since it only counts people who fully loaded the page.</div>
  <table>
    <tr><th>Value (Nepal)</th><th>Remark</th></tr>
    <tr><td>Below $0.03</td><td><span class="pill ex">Excellent</span></td></tr>
    <tr><td>$0.03 – $0.10</td><td><span class="pill g">Good</span></td></tr>
    <tr><td>$0.10 – $0.30</td><td><span class="pill av">Average</span></td></tr>
    <tr><td>$0.30 – $0.60</td><td><span class="pill po">Expensive</span></td></tr>
    <tr><td>$0.60+</td><td><span class="pill po">Very Expensive — fix website speed</span></td></tr>
  </table>
</div>

<div class="card">
  <div class="card-title">Add to Cart Rate</div>
  <div class="card-sub">% of landing page visitors who add to cart</div>
  <div class="card-desc">Formula: Add to Carts ÷ Landing Page Views × 100. Low rate = product page has issues (no reviews, bad images, missing info, bad pricing).</div>
  <table>
    <tr><th>Add to Cart Rate</th><th>Remark</th></tr>
    <tr><td>Below 1%</td><td><span class="pill po">Poor — fix product page urgently</span></td></tr>
    <tr><td>1% – 3%</td><td><span class="pill av">Average — room for improvement</span></td></tr>
    <tr><td>3% – 6%</td><td><span class="pill g">Good</span></td></tr>
    <tr><td>6%+</td><td><span class="pill ex">Excellent</span></td></tr>
  </table>
</div>

<div class="card">
  <div class="card-title">Checkout Rate & Purchase Rate</div>
  <div class="card-sub">How many cart adds turn into purchases</div>
  <div class="card-desc">Low checkout rate = checkout is confusing, payment options missing, or no COD. Low purchase rate = cart abandonment — use retargeting to recover.</div>
  <table>
    <tr><th>Metric</th><th>Good Rate</th><th>Poor Rate</th></tr>
    <tr><td>Initiate Checkout ÷ Add to Cart</td><td><span class="pill g">50%+</span></td><td><span class="pill po">Below 25%</span></td></tr>
    <tr><td>Purchase ÷ Initiate Checkout</td><td><span class="pill g">40%+</span></td><td><span class="pill po">Below 20%</span></td></tr>
    <tr><td>Purchase ÷ Landing Page Views</td><td><span class="pill g">2%+</span></td><td><span class="pill po">Below 0.5%</span></td></tr>
  </table>
</div>

<!-- 04 RESULTS -->
<div class="sec" id="results">04 · Results & Conversions</div>

<div class="card">
  <div class="card-title">Cost Per Result — All Objectives</div>
  <div class="card-sub">How much you pay for each goal completed</div>
  <div class="card-desc">Most important number to judge campaign profitability. Changes completely based on your campaign objective.</div>
  <table>
    <tr><th>Campaign Objective</th><th>Excellent</th><th>Good</th><th>Average</th><th>Poor / Stop</th></tr>
    <tr><td>Purchase / Sales</td><td><span class="pill ex">Below $2</span></td><td><span class="pill g">$2–$5</span></td><td><span class="pill av">$5–$10</span></td><td><span class="pill po">$10+</span></td></tr>
    <tr><td>Add to Cart</td><td><span class="pill ex">Below $0.50</span></td><td><span class="pill g">$0.50–$1.50</span></td><td><span class="pill av">$1.50–$3</span></td><td><span class="pill po">$3+</span></td></tr>
    <tr><td>Initiate Checkout</td><td><span class="pill ex">Below $0.80</span></td><td><span class="pill g">$0.80–$2</span></td><td><span class="pill av">$2–$4</span></td><td><span class="pill po">$4+</span></td></tr>
    <tr><td>Messages / Conversations</td><td><span class="pill ex">Below $0.20</span></td><td><span class="pill g">$0.20–$0.60</span></td><td><span class="pill av">$0.60–$1.50</span></td><td><span class="pill po">$1.50+</span></td></tr>
    <tr><td>Lead Form Submission</td><td><span class="pill ex">Below $0.50</span></td><td><span class="pill g">$0.50–$1.50</span></td><td><span class="pill av">$1.50–$3</span></td><td><span class="pill po">$3+</span></td></tr>
    <tr><td>Profile Visit (Instagram)</td><td><span class="pill ex">Below $0.01</span></td><td><span class="pill g">$0.01–$0.05</span></td><td><span class="pill av">$0.05–$0.15</span></td><td><span class="pill po">$0.15+</span></td></tr>
    <tr><td>Link Clicks / Traffic</td><td><span class="pill ex">Below $0.02</span></td><td><span class="pill g">$0.02–$0.10</span></td><td><span class="pill av">$0.10–$0.30</span></td><td><span class="pill po">$0.30+</span></td></tr>
    <tr><td>Post Engagement</td><td><span class="pill ex">Below $0.01</span></td><td><span class="pill g">$0.01–$0.05</span></td><td><span class="pill av">$0.05–$0.15</span></td><td><span class="pill po">$0.15+</span></td></tr>
